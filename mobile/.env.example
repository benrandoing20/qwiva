# Supabase project URL — find it in your Supabase dashboard under Project Settings > API
EXPO_PUBLIC_SUPABASE_URL=

# Supabase anon/public key — find it in Project Settings > API > Project API keys
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Qwiva backend (FastAPI) base URL.
# Local dev: use your Mac's LAN IP, e.g. http://192.168.1.42:8000
# (NOT http://localhost:8000 — Expo Go on a real iPhone can't reach the Mac's loopback)
# Production: https://your-fly-app.fly.dev
EXPO_PUBLIC_API_URL=
