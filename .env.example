# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-legacy-jwt-secret   # Settings > API > JWT Secret (use legacy key)

# NVIDIA Inference Hub (embeddings + LLM + reranker)
NVIDIA_API_KEY=ihub_...
NVIDIA_API_BASE=https://inference-api.nvidia.com/v1/
EMBEDDING_MODEL=azure/openai/text-embedding-3-small
LITELLM_MODEL=openai/aws/anthropic/bedrock-claude-sonnet-4-6
RERANK_MODEL=nvidia/nvidia/llama-3.2-nv-rerankqa-1b-v2
RERANK_BASE_URL=https://inference-api.nvidia.com/v1/rerank

# Langfuse observability (optional — get keys from cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Deployment
FRONTEND_URL=https://your-app.vercel.app   # set to Railway env, used for CORS

# Frontend (Next.js — copy to frontend/.env.local)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=https://your-backend.railway.app

QDRANT_URL=https://xxxx.us-east.aws.cloud.qdrant.io
QDRANT_API_KEY=your-api-key
QDRANT_COLLECTION=qwiva_docs