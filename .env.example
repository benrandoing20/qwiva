# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret          # Settings > API > JWT Secret

# NVIDIA Inference Hub (embeddings + LLM)
NVIDIA_API_KEY=ihub_...
NVIDIA_API_BASE=https://inference-api.nvidia.com/v1/
EMBEDDING_MODEL=azure/openai/text-embedding-ada-002
LITELLM_MODEL=openai/us/aws/anthropic/bedrock-claude-opus-4-6

# Cohere reranker
COHERE_API_KEY=...

# Frontend (Next.js public vars)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000
