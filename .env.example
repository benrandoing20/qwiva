# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-legacy-jwt-secret   # Settings > API > JWT Secret (use legacy key)

# Anthropic — main generation model (direct, no routing overhead, prompt caching enabled)
ANTHROPIC_API_KEY=sk-ant-...
LITELLM_MODEL=anthropic/claude-haiku-4-5-20251001   # or claude-sonnet-4-6 for higher quality

# OpenAI — embeddings (text-embedding-3-small direct, same model as ingestion)
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small

# Groq — classify + suggestions (~50–150ms LPU inference)
GROQ_API_KEY=gsk_...
CLASSIFY_MODEL=groq/llama-3.3-70b-versatile

# NVIDIA Inference Hub — reranker only
NVIDIA_API_KEY=ihub_...
NVIDIA_API_BASE=https://inference-api.nvidia.com/v1/
RERANK_MODEL=nvidia/nvidia/llama-3.2-nv-rerankqa-1b-v2
RERANK_BASE_URL=https://inference-api.nvidia.com/v1/rerank

# Qdrant vector store
QDRANT_URL=https://xxxx.us-east.aws.cloud.qdrant.io
QDRANT_API_KEY=your-api-key
QDRANT_COLLECTION=qwiva_docs

# Langfuse observability (optional)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Deployment
FRONTEND_URL=https://your-app.vercel.app

# Frontend (Next.js — copy to frontend/.env.local)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com
