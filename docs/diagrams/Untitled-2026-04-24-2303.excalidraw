      "text": "/                    — Main chat; state machine; SSE stream;\n                       renumberByAppearance(); conv tree\n/learn               — Learning hub (CME credit tracks)\n/discover            — Content discovery\n/community           — Social feed (posts, comments, likes)\n/community/post/[id] — Single post + comment thread\n/surveys             — Survey list\n/surveys/[id]        — Survey response form\n/surveys/create      — Admin survey builder\n/profile/[id]        — User profile + specialty + XP\n/auth/login          — Email/password sign-in + create account\n/auth/callback       — Supabase OAuth redirect handler\n/onboarding          — Specialty + cadre selection flow\nlayout.tsx           — Root layout: Navbar + ThemeProvider",
      "fontSize": 9,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "/                    — Main chat; state machine; SSE stream;\n                       renumberByAppearance(); conv tree\n/learn               — Learning hub (CME credit tracks)\n/discover            — Content discovery\n/community           — Social feed (posts, comments, likes)\n/community/post/[id] — Single post + comment thread\n/surveys             — Survey list\n/surveys/[id]        — Survey response form\n/surveys/create      — Admin survey builder\n/profile/[id]        — User profile + specialty + XP\n/auth/login          — Email/password sign-in + create account\n/auth/callback       — Supabase OAuth redirect handler\n/onboarding          — Specialty + cadre selection flow\nlayout.tsx           — Root layout: Navbar + ThemeProvider",
      "lineHeight": 1.25,
      "index": "b23",
      "autoResize": true
    },
