      "updated": 1777442117487,
      "link": null,
      "locked": false,
      "text": "index.tsx         — Landing: Sign up / Log in\nregister.tsx      — Name, email, password\n                    Supabase signUp()\nphone.tsx         — Country code + phone number\nverify.tsx        — Cadre selection:\n                    · Medical Practitioner\n                    · Clinical Officer\n                    · Dental Practitioner\n                    · Intern\n                    + registration number\nspecialty.tsx     — Select specialties\n                    (filtered by cadre, max 3)\nrotation.tsx      — Rotation picker (Intern only)\nlogin.tsx         — Sign-in (Supabase signIn)\nforgot-password   — Reset email flow\nreset-password    — Confirm new password\ntrial-ask.tsx     — Anonymous query before auth\nverify-test.tsx   — Onboarding gate check\n\nStack nav: slide_from_right + swipe-back\nAuth listener in _layout.tsx\nDeep links: qwiva:// schema",
      "fontSize": 9,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "index.tsx         — Landing: Sign up / Log in\nregister.tsx      — Name, email, password\n                    Supabase signUp()\nphone.tsx         — Country code + phone number\nverify.tsx        — Cadre selection:\n                    · Medical Practitioner\n                    · Clinical Officer\n                    · Dental Practitioner\n                    · Intern\n                    + registration number\nspecialty.tsx     — Select specialties\n                    (filtered by cadre, max 3)\nrotation.tsx      — Rotation picker (Intern only)\nlogin.tsx         — Sign-in (Supabase signIn)\nforgot-password   — Reset email flow\nreset-password    — Confirm new password\ntrial-ask.tsx     — Anonymous query before auth\nverify-test.tsx   — Onboarding gate check\n\nStack nav: slide_from_right + swipe-back\nAuth listener in _layout.tsx\nDeep links: qwiva:// schema",
      "lineHeight": 1.25,
