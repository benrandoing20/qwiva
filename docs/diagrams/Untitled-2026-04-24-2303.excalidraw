      "link": null,
      "locked": false,
      "text": "Navbar.tsx            — Fixed top nav, user menu, sign-out\nAnswerCard.tsx        — Streaming text + collapsible citations\nChatInput.tsx         — Auto-grow textarea (Enter=send)\nConversationSidebar   — List / create / delete conversations\nStreamingText.tsx     — Markdown + [1][2]→[1-3] compression\nPostCard.tsx          — Author, content, likes count\nCommentThread.tsx     — Nested comments with replies\nPostComposer.tsx      — New post textarea\nFeaturedCitationCard  — Source card with guideline info\nSpecialtyBadge.tsx    — User specialty tag\nThemeProvider.tsx     — Dark/light theme context\nThemeToggle.tsx       — Theme switch button\nFollowButton.tsx      — Follow / unfollow toggle\nBrandLogo.tsx         — Logo mark\nPHProvider.tsx        — PostHog pageview + event wrapper",
      "fontSize": 9,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Navbar.tsx            — Fixed top nav, user menu, sign-out\nAnswerCard.tsx        — Streaming text + collapsible citations\nChatInput.tsx         — Auto-grow textarea (Enter=send)\nConversationSidebar   — List / create / delete conversations\nStreamingText.tsx     — Markdown + [1][2]→[1-3] compression\nPostCard.tsx          — Author, content, likes count\nCommentThread.tsx     — Nested comments with replies\nPostComposer.tsx      — New post textarea\nFeaturedCitationCard  — Source card with guideline info\nSpecialtyBadge.tsx    — User specialty tag\nThemeProvider.tsx     — Dark/light theme context\nThemeToggle.tsx       — Theme switch button\nFollowButton.tsx      — Follow / unfollow toggle\nBrandLogo.tsx         — Logo mark\nPHProvider.tsx        — PostHog pageview + event wrapper",
      "lineHeight": 1.25,
      "index": "b27",
      "autoResize": true
    },
