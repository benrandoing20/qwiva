      "link": null,
      "locked": false,
      "text": "user_id             UUID PK FK auth.users CASCADE\ndisplay_name        TEXT NOT NULL\nspecialty           TEXT\nsubspecialty        TEXT\ninstitution         TEXT\ncountry             TEXT NOT NULL DEFAULT 'Kenya'\ncity                TEXT\nbio                 TEXT\navatar_url          TEXT\nyears_experience    INT\nmedical_license     TEXT\nverification_status TEXT NOT NULL DEFAULT 'unverified'\n                    CHECK IN (unverified, pending, verified)\nlanguages           TEXT[] DEFAULT '{}'\ninterests           TEXT[] DEFAULT '{}'\nonboarding_complete BOOLEAN DEFAULT FALSE\nfollower_count      INT DEFAULT 0\nfollowing_count     INT DEFAULT 0\npost_count          INT DEFAULT 0\ncreated_at, updated_at\n\nRLS\n  read: anyone (true)\n  insert/update: own only (auth.uid() = user_id)\n\nAUTO-CREATE on auth.users INSERT (handle_new_user)\n  display_name = split_part(email, '@', 1)\n  country = 'Kenya'",
      "fontSize": 9,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "user_id             UUID PK FK auth.users CASCADE\ndisplay_name        TEXT NOT NULL\nspecialty           TEXT\nsubspecialty        TEXT\ninstitution         TEXT\ncountry             TEXT NOT NULL DEFAULT 'Kenya'\ncity                TEXT\nbio                 TEXT\navatar_url          TEXT\nyears_experience    INT\nmedical_license     TEXT\nverification_status TEXT NOT NULL DEFAULT 'unverified'\n                    CHECK IN (unverified, pending, verified)\nlanguages           TEXT[] DEFAULT '{}'\ninterests           TEXT[] DEFAULT '{}'\nonboarding_complete BOOLEAN DEFAULT FALSE\nfollower_count      INT DEFAULT 0\nfollowing_count     INT DEFAULT 0\npost_count          INT DEFAULT 0\ncreated_at, updated_at\n\nRLS\n  read: anyone (true)\n  insert/update: own only (auth.uid() = user_id)\n\nAUTO-CREATE on auth.users INSERT (handle_new_user)\n  display_name = split_part(email, '@', 1)\n  country = 'Kenya'",
      "lineHeight": 1.25
    },
