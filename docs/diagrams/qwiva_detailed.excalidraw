      "text": "CONVERSATIONS  +  TREE",
      "fontSize": 10,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": null,
      "originalText": "CONVERSATIONS  +  TREE",
      "lineHeight": 1.25
    },
    {
      "id": "api_c2_t",
      "type": "text",
      "x": 678,
      "y": 5944,
      "width": 628,
      "height": 638,
      "angle": 0,
      "strokeColor": "#334155",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 39058,
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1745800000000,
      "link": null,
      "locked": false,
      "text": "GET    /conversations\n  list_conversations(user_id) \u2192 ConversationSummary[]\n  TTL cache 30s \u00b7 ordered by updated_at DESC \u00b7 limit 50\n\nPOST   /conversations\n  create_conversation() \u2192 new ConversationSummary\n\nGET    /conversations/{id}/messages\n  get_active_path RPC \u2192 MessageOut[]\n  recursive CTE follows selected_child_id root \u2192 leaf\n  enriched with suggestions column (separate query)\n\nGET    /conversations/{id}/messages/{mid}/siblings\n  get_siblings RPC \u2192 SiblingOut[]\n  branches at fork point ordered by branch_index\n\nPATCH  /conversations/{id}/messages/{mid}/branch\n  query: ?child_id=...  switches selected_child_id\n\nPATCH  /conversations/{id}/title\n  manual title override \u00b7 marks title_generated=true\n\nDELETE /conversations/{id}\n  cascade-deletes all messages + branches\n\nInternal RPCs (collapsed multi-call \u2192 single round-trip)\n  append_user_message(conv, content, parent)\n  append_assistant_message(conv, parent, content,\n                            citations, evidence_grade)\n  Both have 2/3-call Python fallbacks if RPC missing",
      "fontSize": 9,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "GET    /conversations\n  list_conversations(user_id) \u2192 ConversationSummary[]\n  TTL cache 30s \u00b7 ordered by updated_at DESC \u00b7 limit 50\n\nPOST   /conversations\n  create_conversation() \u2192 new ConversationSummary\n\nGET    /conversations/{id}/messages\n  get_active_path RPC \u2192 MessageOut[]\n  recursive CTE follows selected_child_id root \u2192 leaf\n  enriched with suggestions column (separate query)\n\nGET    /conversations/{id}/messages/{mid}/siblings\n  get_siblings RPC \u2192 SiblingOut[]\n  branches at fork point ordered by branch_index\n\nPATCH  /conversations/{id}/messages/{mid}/branch\n  query: ?child_id=...  switches selected_child_id\n\nPATCH  /conversations/{id}/title\n  manual title override \u00b7 marks title_generated=true\n\nDELETE /conversations/{id}\n  cascade-deletes all messages + branches\n\nInternal RPCs (collapsed multi-call \u2192 single round-trip)\n  append_user_message(conv, content, parent)\n  append_assistant_message(conv, parent, content,\n                            citations, evidence_grade)\n  Both have 2/3-call Python fallbacks if RPC missing",
      "lineHeight": 1.25
    },
