      "text": "AUTH \u00b7 PROFILE \u00b7 SEARCH",
      "fontSize": 10,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": null,
      "originalText": "AUTH \u00b7 PROFILE \u00b7 SEARCH",
      "lineHeight": 1.25
    },
    {
      "id": "api_c1_t",
      "type": "text",
      "x": 28,
      "y": 5944,
      "width": 628,
      "height": 638,
      "angle": 0,
      "strokeColor": "#334155",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 96962,
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1745800000000,
      "link": null,
      "locked": false,
      "text": "AUTH\n  GET  /health                     {ok: true}\n  GET  /me                         UserProfile from JWT\n    HTTPBearer \u00b7 HS256 \u00b7 sub+exp required \u00b7 verify_aud=False\n\nPROFILES + ONBOARDING\n  GET  /profile/me                 PhysicianProfileOut (lazy-create)\n  PUT  /profile/me                 ProfileUpdateRequest \u2192 upsert\n  POST /profile/me/onboarding      OnboardingRequest \u2192 marks complete\n  GET  /profile/{user_id}          PhysicianProfileOut + is_following\n\nSEARCH  (RAG streaming endpoint)\n  POST /search/stream              SearchRequest\n    rate-limited: 15/min per user_id (or IP)\n    body: { query, conversation_id?, parent_message_id? }\n    response: text/event-stream\n    max query: 2000 chars\n    auto-creates conversation if conversation_id stale\n    title generated in parallel with embed (Groq)\n    persists user msg + assistant msg + filtered citations\n    citations filtered to those actually cited [n] in answer",
      "fontSize": 9,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "AUTH\n  GET  /health                     {ok: true}\n  GET  /me                         UserProfile from JWT\n    HTTPBearer \u00b7 HS256 \u00b7 sub+exp required \u00b7 verify_aud=False\n\nPROFILES + ONBOARDING\n  GET  /profile/me                 PhysicianProfileOut (lazy-create)\n  PUT  /profile/me                 ProfileUpdateRequest \u2192 upsert\n  POST /profile/me/onboarding      OnboardingRequest \u2192 marks complete\n  GET  /profile/{user_id}          PhysicianProfileOut + is_following\n\nSEARCH  (RAG streaming endpoint)\n  POST /search/stream              SearchRequest\n    rate-limited: 15/min per user_id (or IP)\n    body: { query, conversation_id?, parent_message_id? }\n    response: text/event-stream\n    max query: 2000 chars\n    auto-creates conversation if conversation_id stale\n    title generated in parallel with embed (Groq)\n    persists user msg + assistant msg + filtered citations\n    citations filtered to those actually cited [n] in answer",
      "lineHeight": 1.25
    },
