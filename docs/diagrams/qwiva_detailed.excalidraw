      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1745800000000,
      "link": null,
      "locked": false,
      "text": "MODEL PREFIX \u2192 CREDENTIALS\n\ngroq/*           GROQ_API_KEY\nopenai/aws/*     NVIDIA hub\n                  (Bedrock route)\nopenai/azure/*   NVIDIA hub\n                  (Azure route)\nopenai/*         OpenAI direct\n                  fallback NVIDIA\nanthropic/*      ANTHROPIC_API_KEY\n\nPre-warmed on startup\n  _openai \u00b7 _http\n  _qdrant \u00b7 _extra_kwargs\n  _classify_kwargs \u00b7 db pool\n\nLANGFUSE TRACING (opt)\n  litellm.success_callback\n  trace_name + tags + user_id\n  qwiva_search \u00b7 qwiva_chat\n  trace_metadata.num_sources\n  Compat patch: drops\n  sdk_integration kwarg",
      "fontSize": 9,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "MODEL PREFIX \u2192 CREDENTIALS\n\ngroq/*           GROQ_API_KEY\nopenai/aws/*     NVIDIA hub\n                  (Bedrock route)\nopenai/azure/*   NVIDIA hub\n                  (Azure route)\nopenai/*         OpenAI direct\n                  fallback NVIDIA\nanthropic/*      ANTHROPIC_API_KEY\n\nPre-warmed on startup\n  _openai \u00b7 _http\n  _qdrant \u00b7 _extra_kwargs\n  _classify_kwargs \u00b7 db pool\n\nLANGFUSE TRACING (opt)\n  litellm.success_callback\n  trace_name + tags + user_id\n  qwiva_search \u00b7 qwiva_chat\n  trace_metadata.num_sources\n  Compat patch: drops\n  sdk_integration kwarg",
      "lineHeight": 1.25
    },
