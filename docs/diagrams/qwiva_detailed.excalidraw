    {
      "id": "rpc_c1_t",
      "type": "text",
      "x": 28,
      "y": 7584,
      "width": 628,
      "height": 538,
      "angle": 0,
      "strokeColor": "#334155",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 84589,
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1745800000000,
      "link": null,
      "locked": false,
      "text": "match_documents(query_embedding, match_count)\n  Simple HNSW cosine vector search on documents_v2\n  ORDER BY embedding <=> query_embedding \u00b7 LIMIT n\n  Returns: id, content, metadata, similarity\n\ndynamic_hybrid_search_db(...)  (legacy fallback)\n  Vector + FTS + ilike + fuzzy with weighted RRF merge\n  Used only when QDRANT_URL is not configured\n  Args: query_embedding, query_text, dense_weight,\n        sparse_weight, ilike_weight, fuzzy_weight,\n        rrf_k, match_count, filter, fuzzy_threshold\n  Default rag.py weights: dense=0.6, sparse=0.4\n\nsearch_cpg_fts(query_text, match_count)\n  Full-text websearch_to_tsquery on\n  clinical_practice_guideline_chunks\n  Ordered by ts_rank \u2014 relevance, not insertion\n\nsearch_pubmed_fts(query_text, match_count)\n  Same FTS pattern on guideline_chunks (PubMed)\n  Both called in parallel via asyncio.gather\n\nget_chunks_by_ranges(input_data jsonb)\n  Context expansion: fetches contiguous chunks\n  by [doc_id, [start, end]] ranges\n  Used for surrounding-chunk hydration around hits",
      "fontSize": 9,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "match_documents(query_embedding, match_count)\n  Simple HNSW cosine vector search on documents_v2\n  ORDER BY embedding <=> query_embedding \u00b7 LIMIT n\n  Returns: id, content, metadata, similarity\n\ndynamic_hybrid_search_db(...)  (legacy fallback)\n  Vector + FTS + ilike + fuzzy with weighted RRF merge\n  Used only when QDRANT_URL is not configured\n  Args: query_embedding, query_text, dense_weight,\n        sparse_weight, ilike_weight, fuzzy_weight,\n        rrf_k, match_count, filter, fuzzy_threshold\n  Default rag.py weights: dense=0.6, sparse=0.4\n\nsearch_cpg_fts(query_text, match_count)\n  Full-text websearch_to_tsquery on\n  clinical_practice_guideline_chunks\n  Ordered by ts_rank \u2014 relevance, not insertion\n\nsearch_pubmed_fts(query_text, match_count)\n  Same FTS pattern on guideline_chunks (PubMed)\n  Both called in parallel via asyncio.gather\n\nget_chunks_by_ranges(input_data jsonb)\n  Context expansion: fetches contiguous chunks\n  by [doc_id, [start, end]] ranges\n  Used for surrounding-chunk hydration around hits",
      "lineHeight": 1.25
    },
