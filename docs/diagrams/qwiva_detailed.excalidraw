    {
      "id": "llm_nv_t",
      "type": "text",
      "x": 1064,
      "y": 6688,
      "width": 490,
      "height": 394,
      "angle": 0,
      "strokeColor": "#334155",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 66381,
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1745800000000,
      "link": null,
      "locked": false,
      "text": "Reranker (direct GPU call)\nllama-3.2-nv-rerankqa-1b-v2\n\nROLE\n  Rerank top-40 \u2192 top-10\n  After RRF merge\n\nEndpoint\n  POST /v1/rerank\n  via httpx.AsyncClient\n  http2=True \u00b7 timeout 90s\n\nTruncate docs to 1800ch\n  at sentence boundary\n  query capped at 500ch\n\nRetry 3\u00d7 with backoff\n  400 \u2192 halve doc length\n  429/5xx \u2192 2^attempt\n  fall back to top-N\n  unranked on failure\n\nAuth: NVIDIA_API_KEY",
      "fontSize": 9,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Reranker (direct GPU call)\nllama-3.2-nv-rerankqa-1b-v2\n\nROLE\n  Rerank top-40 \u2192 top-10\n  After RRF merge\n\nEndpoint\n  POST /v1/rerank\n  via httpx.AsyncClient\n  http2=True \u00b7 timeout 90s\n\nTruncate docs to 1800ch\n  at sentence boundary\n  query capped at 500ch\n\nRetry 3\u00d7 with backoff\n  400 \u2192 halve doc length\n  429/5xx \u2192 2^attempt\n  fall back to top-N\n  unranked on failure\n\nAuth: NVIDIA_API_KEY",
      "lineHeight": 1.25
    },
