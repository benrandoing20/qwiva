    {
      "id": "svy_svr_t",
      "type": "text",
      "x": 1328,
      "y": 8236,
      "width": 622,
      "height": 464,
      "angle": 0,
      "strokeColor": "#334155",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 99885,
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1745800000000,
      "link": null,
      "locked": false,
      "text": "id         UUID PK\nsurvey_id  UUID FK CASCADE\nuser_id    UUID FK user_profiles\ncreated_at TIMESTAMPTZ\n\nUNIQUE (survey_id, user_id)\n  one response per user\n  per survey \u00b7 enforced\n  in DB (not just app)\n\nINDEXES\n  survey_id\n  user_id\n\nRLS\n  insert: auth.uid()=user_id\n  read: own response OR\n        creator of survey OR\n        any admin\n\nTRIGGER\n  AFTER INSERT \u2192\n  increment_survey_\n  response_count()\n  bumps surveys.\n  response_count + 1",
      "fontSize": 9,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "id         UUID PK\nsurvey_id  UUID FK CASCADE\nuser_id    UUID FK user_profiles\ncreated_at TIMESTAMPTZ\n\nUNIQUE (survey_id, user_id)\n  one response per user\n  per survey \u00b7 enforced\n  in DB (not just app)\n\nINDEXES\n  survey_id\n  user_id\n\nRLS\n  insert: auth.uid()=user_id\n  read: own response OR\n        creator of survey OR\n        any admin\n\nTRIGGER\n  AFTER INSERT \u2192\n  increment_survey_\n  response_count()\n  bumps surveys.\n  response_count + 1",
      "lineHeight": 1.25
    },
