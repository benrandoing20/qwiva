      "lineHeight": 1.25
    },
    {
      "id": "rpc_c4_t",
      "type": "text",
      "x": 1978,
      "y": 7584,
      "width": 638,
      "height": 538,
      "angle": 0,
      "strokeColor": "#334155",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 14193,
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1745800000000,
      "link": null,
      "locked": false,
      "text": "TIMESTAMP TOUCHES (BEFORE UPDATE)\n  touch_conversation  on messages INSERT\n                      bumps conversations.updated_at\n  touch_profile       on user_profiles UPDATE\n  touch_post          on posts UPDATE\n  touch_survey        on surveys UPDATE\n\nUSER LIFECYCLE\n  handle_new_user     on auth.users INSERT\n                      INSERT INTO user_profiles\n                      (split email at @ for display_name,\n                       country='Kenya')\n                      ON CONFLICT DO NOTHING\n\nCOUNTER MAINTENANCE\n  update_user_post_count       on posts INSERT/UPDATE\n                                bumps user_profiles.post_count\n                                decrements on soft-delete\n  update_post_like_count       on post_likes INSERT/DELETE\n                                posts.like_count \u00b1 1\n  update_comment_like_count    on comment_likes INSERT/DELETE\n                                comments.like_count \u00b1 1\n  update_post_comment_count    on comments INSERT/UPDATE\n                                posts.comment_count \u00b1 1\n  update_follow_counts         on follows INSERT/DELETE\n                                follower / following counts\n  increment_survey_response_count\n                                on survey_responses INSERT\n                                surveys.response_count + 1\n\nAll counter triggers use SECURITY DEFINER\n  (so they update counts even from RLS-restricted writes)",
      "fontSize": 9,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "TIMESTAMP TOUCHES (BEFORE UPDATE)\n  touch_conversation  on messages INSERT\n                      bumps conversations.updated_at\n  touch_profile       on user_profiles UPDATE\n  touch_post          on posts UPDATE\n  touch_survey        on surveys UPDATE\n\nUSER LIFECYCLE\n  handle_new_user     on auth.users INSERT\n                      INSERT INTO user_profiles\n                      (split email at @ for display_name,\n                       country='Kenya')\n                      ON CONFLICT DO NOTHING\n\nCOUNTER MAINTENANCE\n  update_user_post_count       on posts INSERT/UPDATE\n                                bumps user_profiles.post_count\n                                decrements on soft-delete\n  update_post_like_count       on post_likes INSERT/DELETE\n                                posts.like_count \u00b1 1\n  update_comment_like_count    on comment_likes INSERT/DELETE\n                                comments.like_count \u00b1 1\n  update_post_comment_count    on comments INSERT/UPDATE\n                                posts.comment_count \u00b1 1\n  update_follow_counts         on follows INSERT/DELETE\n                                follower / following counts\n  increment_survey_response_count\n                                on survey_responses INSERT\n                                surveys.response_count + 1\n\nAll counter triggers use SECURITY DEFINER\n  (so they update counts even from RLS-restricted writes)",
      "lineHeight": 1.25
    },
