    {
      "id": "svy_svt_t",
      "type": "text",
      "x": 28,
      "y": 8236,
      "width": 622,
      "height": 464,
      "angle": 0,
      "strokeColor": "#334155",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 98581,
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1745800000000,
      "link": null,
      "locked": false,
      "text": "id          UUID PK\ncreated_by  UUID FK user_profiles\ntitle       TEXT NOT NULL\n            CHECK 1..200 chars\ndescription TEXT\nspecialty_tags TEXT[]\nstatus      TEXT NOT NULL DEFAULT 'draft'\n            CHECK IN (draft, active, closed)\nis_anonymous BOOLEAN\nestimated_minutes INT\nresponse_count INT DEFAULT 0\nstarts_at   TIMESTAMPTZ\nends_at     TIMESTAMPTZ\ncreated_at  TIMESTAMPTZ\nupdated_at  TIMESTAMPTZ\n\nINDEXES\n  status, created_at DESC\n  created_by\n  GIN specialty_tags\n\nRLS\n  read: status=active OR creator\n  insert: admin only\n  update: admin only\n\nTRIGGER\n  touch_survey BEFORE UPDATE\n\nVALID TRANSITIONS\n  draft  \u2192 active\n  active \u2192 closed\n  (others rejected 422)",
      "fontSize": 9,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "id          UUID PK\ncreated_by  UUID FK user_profiles\ntitle       TEXT NOT NULL\n            CHECK 1..200 chars\ndescription TEXT\nspecialty_tags TEXT[]\nstatus      TEXT NOT NULL DEFAULT 'draft'\n            CHECK IN (draft, active, closed)\nis_anonymous BOOLEAN\nestimated_minutes INT\nresponse_count INT DEFAULT 0\nstarts_at   TIMESTAMPTZ\nends_at     TIMESTAMPTZ\ncreated_at  TIMESTAMPTZ\nupdated_at  TIMESTAMPTZ\n\nINDEXES\n  status, created_at DESC\n  created_by\n  GIN specialty_tags\n\nRLS\n  read: status=active OR creator\n  insert: admin only\n  update: admin only\n\nTRIGGER\n  touch_survey BEFORE UPDATE\n\nVALID TRANSITIONS\n  draft  \u2192 active\n  active \u2192 closed\n  (others rejected 422)",
      "lineHeight": 1.25
    },
