    },
    {
      "id": "up_c3_t",
      "type": "text",
      "x": 1368,
      "y": 8804,
      "width": 1248,
      "height": 378,
      "angle": 0,
      "strokeColor": "#334155",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 35233,
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1745800000000,
      "link": null,
      "locked": false,
      "text": "ALTER TABLE user_profiles  (all ADD COLUMN IF NOT EXISTS)\n  first_name           TEXT             \u2190 register screen\n  last_name            TEXT             \u2190 register screen\n  phone                TEXT             \u2190 phone screen\n  cadre                TEXT             \u2190 verify screen\n                       CHECK IN ('Medical Practitioner',\n                                 'Clinical Officer',\n                                 'Dental Practitioner',\n                                 'Intern')\n  registration_number  TEXT             \u2190 verify screen\n  specialties          TEXT[] DEFAULT '{}'  \u2190 specialty screen (\u22643)\n  current_rotation     TEXT[] DEFAULT '{}'  \u2190 rotation screen (Intern only)\n\nBACKFILL (best-effort, runs once at migration)\n  UPDATE user_profiles SET first_name = split_part(display_name, ' ', 1),\n                            last_name  = NULLIF(trim(substring(display_name FROM\n                                                position(' ' IN display_name) + 1)), '')\n  WHERE first_name IS NULL AND display_name has space\n\nMOBILE ONBOARDING FLOW WIRES INTO THESE\n  register   \u2192 first_name, last_name, email + password (Supabase Auth)\n  phone      \u2192 phone\n  verify     \u2192 cadre, registration_number\n  specialty  \u2192 specialties[]   (filtered by cadre)\n  rotation   \u2192 current_rotation[]   (Intern cadre only)\n  \u2193\n  POST /profile/me/onboarding   sets onboarding_complete=true,\n                                 derives display_name from first+last name",
      "fontSize": 9,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "ALTER TABLE user_profiles  (all ADD COLUMN IF NOT EXISTS)\n  first_name           TEXT             \u2190 register screen\n  last_name            TEXT             \u2190 register screen\n  phone                TEXT             \u2190 phone screen\n  cadre                TEXT             \u2190 verify screen\n                       CHECK IN ('Medical Practitioner',\n                                 'Clinical Officer',\n                                 'Dental Practitioner',\n                                 'Intern')\n  registration_number  TEXT             \u2190 verify screen\n  specialties          TEXT[] DEFAULT '{}'  \u2190 specialty screen (\u22643)\n  current_rotation     TEXT[] DEFAULT '{}'  \u2190 rotation screen (Intern only)\n\nBACKFILL (best-effort, runs once at migration)\n  UPDATE user_profiles SET first_name = split_part(display_name, ' ', 1),\n                            last_name  = NULLIF(trim(substring(display_name FROM\n                                                position(' ' IN display_name) + 1)), '')\n  WHERE first_name IS NULL AND display_name has space\n\nMOBILE ONBOARDING FLOW WIRES INTO THESE\n  register   \u2192 first_name, last_name, email + password (Supabase Auth)\n  phone      \u2192 phone\n  verify     \u2192 cadre, registration_number\n  specialty  \u2192 specialties[]   (filtered by cadre)\n  rotation   \u2192 current_rotation[]   (Intern cadre only)\n  \u2193\n  POST /profile/me/onboarding   sets onboarding_complete=true,\n                                 derives display_name from first+last name",
      "lineHeight": 1.25
    },
