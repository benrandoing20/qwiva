    {
      "id": "rpc_c2_t",
      "type": "text",
      "x": 678,
      "y": 7584,
      "width": 628,
      "height": 538,
      "angle": 0,
      "strokeColor": "#334155",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
