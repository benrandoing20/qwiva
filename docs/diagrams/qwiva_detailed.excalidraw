    {
      "id": "b1_conv_t",
      "type": "text",
      "x": 28,
      "y": 1922,
      "width": 412,
      "height": 772,
      "angle": 0,
      "strokeColor": "#1e3a8a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
