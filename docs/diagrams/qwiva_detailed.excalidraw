      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 76903,
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1745800000000,
      "link": null,
      "locked": false,
      "text": "get_active_path(p_conversation_id)\n  WITH RECURSIVE \u2014 root \u2192 leaf via selected_child_id\n  ORDER BY created_at\n  Returns full message records on the active branch\n  SECURITY DEFINER (bypasses RLS for service key)\n\nget_siblings(p_parent_id)\n  All children of a parent message (branch fork)\n  ORDER BY branch_index\n  Powers the branch switcher UI\n\nappend_user_message(p_conv, p_content, p_parent)\n  Inserts user message + updates parent's\n  selected_child_id in 1 round-trip\n  Computes branch_index from sibling count\n  Backend has 3-call Python fallback\n\nappend_assistant_message(p_conv, p_parent, p_content,\n                         p_citations, p_evidence_grade)\n  Inserts assistant message + updates parent's\n  selected_child_id in 1 round-trip\n  Backend has 2-call Python fallback\n\nTree invariants\n  parent_id NULL  \u2192 root (first user message)\n  selected_child_id NULL \u2192 leaf (active head)\n  branch_index 0 = original  \u00b7 1,2... = edits\n  Edit creates a new branch, not in-place mutation",
      "fontSize": 9,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "get_active_path(p_conversation_id)\n  WITH RECURSIVE \u2014 root \u2192 leaf via selected_child_id\n  ORDER BY created_at\n  Returns full message records on the active branch\n  SECURITY DEFINER (bypasses RLS for service key)\n\nget_siblings(p_parent_id)\n  All children of a parent message (branch fork)\n  ORDER BY branch_index\n  Powers the branch switcher UI\n\nappend_user_message(p_conv, p_content, p_parent)\n  Inserts user message + updates parent's\n  selected_child_id in 1 round-trip\n  Computes branch_index from sibling count\n  Backend has 3-call Python fallback\n\nappend_assistant_message(p_conv, p_parent, p_content,\n                         p_citations, p_evidence_grade)\n  Inserts assistant message + updates parent's\n  selected_child_id in 1 round-trip\n  Backend has 2-call Python fallback\n\nTree invariants\n  parent_id NULL  \u2192 root (first user message)\n  selected_child_id NULL \u2192 leaf (active head)\n  branch_index 0 = original  \u00b7 1,2... = edits\n  Edit creates a new branch, not in-place mutation",
      "lineHeight": 1.25
    },
