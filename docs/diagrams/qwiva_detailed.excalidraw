      "text": "SURVEYS  (admin-gated)",
      "fontSize": 10,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": null,
      "originalText": "SURVEYS  (admin-gated)",
      "lineHeight": 1.25
    },
    {
      "id": "api_c4_t",
      "type": "text",
      "x": 1978,
      "y": 5944,
      "width": 638,
      "height": 638,
      "angle": 0,
      "strokeColor": "#334155",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 35334,
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1745800000000,
      "link": null,
      "locked": false,
      "text": "GET    /surveys\n  status='active' \u00b7 admin sees own drafts merged\n  enriched with has_responded per viewer\n\nGET    /surveys/{id}\n  parallel asyncio.gather:\n    survey row \u00b7 questions (ordered) \u00b7 viewer response\n  \u2192 SurveyOut with embedded questions\n\nPOST   /surveys                    require_admin\n  body: SurveyCreate { title, description, questions[],\n                       specialty_tags, status, dates, ... }\n  questions inserted in batch \u00b7 rolls back on error\n\nPATCH  /surveys/{id}/status        creator OR admin only\n  valid: draft\u2192active \u00b7 active\u2192closed (no other transitions)\n\nPOST   /surveys/{id}/responses     SurveyResponseCreate\n  enforces UNIQUE (survey_id, user_id) \u2014 422 if already responded\n  inserts response + answer rows \u00b7 trigger increments count\n\nGET    /surveys/{id}/results       creator OR admin only\n  \u2192 SurveyResultsOut\n    multiple_choice / multi_select: option_counts\n    scale: scale_distribution + average_scale\n    open_text: first 200 responses\n\nQuestion types\n  multiple_choice  options:[{id,text}]  one selection\n  multi_select     options:[{id,text}]  multiple\n  scale            scale_min..max + labels\n  open_text        free text answer",
      "fontSize": 9,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "GET    /surveys\n  status='active' \u00b7 admin sees own drafts merged\n  enriched with has_responded per viewer\n\nGET    /surveys/{id}\n  parallel asyncio.gather:\n    survey row \u00b7 questions (ordered) \u00b7 viewer response\n  \u2192 SurveyOut with embedded questions\n\nPOST   /surveys                    require_admin\n  body: SurveyCreate { title, description, questions[],\n                       specialty_tags, status, dates, ... }\n  questions inserted in batch \u00b7 rolls back on error\n\nPATCH  /surveys/{id}/status        creator OR admin only\n  valid: draft\u2192active \u00b7 active\u2192closed (no other transitions)\n\nPOST   /surveys/{id}/responses     SurveyResponseCreate\n  enforces UNIQUE (survey_id, user_id) \u2014 422 if already responded\n  inserts response + answer rows \u00b7 trigger increments count\n\nGET    /surveys/{id}/results       creator OR admin only\n  \u2192 SurveyResultsOut\n    multiple_choice / multi_select: option_counts\n    scale: scale_distribution + average_scale\n    open_text: first 200 responses\n\nQuestion types\n  multiple_choice  options:[{id,text}]  one selection\n  multi_select     options:[{id,text}]  multiple\n  scale            scale_min..max + labels\n  open_text        free text answer",
      "lineHeight": 1.25
    },
