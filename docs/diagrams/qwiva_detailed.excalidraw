      "text": "SOCIAL  \u00b7  FEED  \u00b7  DISCOVER",
      "fontSize": 10,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": null,
      "originalText": "SOCIAL  \u00b7  FEED  \u00b7  DISCOVER",
      "lineHeight": 1.25
    },
    {
      "id": "api_c3_t",
      "type": "text",
      "x": 1328,
      "y": 5944,
      "width": 628,
      "height": 638,
      "angle": 0,
      "strokeColor": "#334155",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 53127,
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1745800000000,
      "link": null,
      "locked": false,
      "text": "FEED\n  GET /feed                        ?cursor&limit&filter=all|following\n  GET /posts/trending              7d engagement-sorted\n  Backed by get_personalized_feed RPC:\n    follow boost \u00d71.5 \u00b7 specialty match \u00d71.2\n    recency decay: 1/(1 + age_days)\n    + 0.10\u00b7ln(likes+1)  + 0.05\u00b7ln(comments+1)\n\nPOSTS\n  POST   /posts                    CreatePostRequest\n    types: question \u00b7 case_discussion \u00b7\n           clinical_pearl \u00b7 resource\n  GET    /posts/{id}               increments view_count\n  DELETE /posts/{id}               soft delete (is_deleted=true)\n  POST   /posts/{id}/like          toggle \u2192 LikeResponse\n\nCOMMENTS\n  GET    /posts/{id}/comments      get_comments_with_context RPC\n  POST   /posts/{id}/comments      supports parent_comment_id (reply)\n  DELETE /comments/{id}            soft delete\n  POST   /comments/{id}/like       toggle \u2192 LikeResponse\n\nFOLLOWS\n  POST   /users/{id}/follow        rejects self-follow (CHECK)\n  DELETE /users/{id}/follow\n  GET    /users/{id}/followers\n  GET    /users/{id}/following\n  GET    /users/{id}/posts         author's posts via feed RPC filter\n\nDISCOVER\n  GET    /discover/users           ?specialty&country&limit&offset\n    discover_users RPC \u00b7 onboarding_complete=true \u00b7 order by\n    follower_count DESC, post_count DESC",
      "fontSize": 9,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "FEED\n  GET /feed                        ?cursor&limit&filter=all|following\n  GET /posts/trending              7d engagement-sorted\n  Backed by get_personalized_feed RPC:\n    follow boost \u00d71.5 \u00b7 specialty match \u00d71.2\n    recency decay: 1/(1 + age_days)\n    + 0.10\u00b7ln(likes+1)  + 0.05\u00b7ln(comments+1)\n\nPOSTS\n  POST   /posts                    CreatePostRequest\n    types: question \u00b7 case_discussion \u00b7\n           clinical_pearl \u00b7 resource\n  GET    /posts/{id}               increments view_count\n  DELETE /posts/{id}               soft delete (is_deleted=true)\n  POST   /posts/{id}/like          toggle \u2192 LikeResponse\n\nCOMMENTS\n  GET    /posts/{id}/comments      get_comments_with_context RPC\n  POST   /posts/{id}/comments      supports parent_comment_id (reply)\n  DELETE /comments/{id}            soft delete\n  POST   /comments/{id}/like       toggle \u2192 LikeResponse\n\nFOLLOWS\n  POST   /users/{id}/follow        rejects self-follow (CHECK)\n  DELETE /users/{id}/follow\n  GET    /users/{id}/followers\n  GET    /users/{id}/following\n  GET    /users/{id}/posts         author's posts via feed RPC filter\n\nDISCOVER\n  GET    /discover/users           ?specialty&country&limit&offset\n    discover_users RPC \u00b7 onboarding_complete=true \u00b7 order by\n    follower_count DESC, post_count DESC",
      "lineHeight": 1.25
    },
