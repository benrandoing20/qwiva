      "updated": 1745700000000,
      "link": null,
      "locked": false,
      "text": "Navbar.tsx            \u2014 Fixed top nav, user menu, sign-out\nAnswerCard.tsx        \u2014 Streaming text + collapsible citations\nChatInput.tsx         \u2014 Auto-grow textarea (Enter=send)\nConversationSidebar   \u2014 List / create / delete conversations\nStreamingText.tsx     \u2014 Markdown + [1][2]\u2192[1-3] compression\nPostCard.tsx          \u2014 Author, content, likes count\nCommentThread.tsx     \u2014 Nested comments with replies\nPostComposer.tsx      \u2014 New post textarea\nFeaturedCitationCard  \u2014 Source card with guideline info\nSpecialtyBadge.tsx    \u2014 User specialty tag\nThemeProvider.tsx     \u2014 Dark/light theme context\nThemeToggle.tsx       \u2014 Theme switch button\nFollowButton.tsx      \u2014 Follow / unfollow toggle\nBrandLogo.tsx         \u2014 Logo mark\nPHProvider.tsx        \u2014 PostHog pageview + event wrapper",
      "fontSize": 9,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Navbar.tsx            \u2014 Fixed top nav, user menu, sign-out\nAnswerCard.tsx        \u2014 Streaming text + collapsible citations\nChatInput.tsx         \u2014 Auto-grow textarea (Enter=send)\nConversationSidebar   \u2014 List / create / delete conversations\nStreamingText.tsx     \u2014 Markdown + [1][2]\u2192[1-3] compression\nPostCard.tsx          \u2014 Author, content, likes count\nCommentThread.tsx     \u2014 Nested comments with replies\nPostComposer.tsx      \u2014 New post textarea\nFeaturedCitationCard  \u2014 Source card with guideline info\nSpecialtyBadge.tsx    \u2014 User specialty tag\nThemeProvider.tsx     \u2014 Dark/light theme context\nThemeToggle.tsx       \u2014 Theme switch button\nFollowButton.tsx      \u2014 Follow / unfollow toggle\nBrandLogo.tsx         \u2014 Logo mark\nPHProvider.tsx        \u2014 PostHog pageview + event wrapper",
      "lineHeight": 1.25
    },
