      "updated": 1745800000000,
      "link": null,
      "locked": false,
      "text": "ALTER TABLE user_profiles\n  ADD COLUMN role TEXT NOT NULL\n    DEFAULT 'physician'\n    CHECK IN ('physician', 'admin')\n\nUsed by\n  surveys insert/update RLS\n  POST /surveys (require_admin dep)\n  PATCH /surveys/{id}/status\n  GET /surveys/{id}/results\n\nBackend gate\n  require_admin() FastAPI Depends:\n    fetches user_profiles row\n    rejects 403 if role!='admin'\n\nSurvey listing\n  admins: own drafts merged with\n          all active surveys\n  others: only active surveys",
      "fontSize": 9,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "ALTER TABLE user_profiles\n  ADD COLUMN role TEXT NOT NULL\n    DEFAULT 'physician'\n    CHECK IN ('physician', 'admin')\n\nUsed by\n  surveys insert/update RLS\n  POST /surveys (require_admin dep)\n  PATCH /surveys/{id}/status\n  GET /surveys/{id}/results\n\nBackend gate\n  require_admin() FastAPI Depends:\n    fetches user_profiles row\n    rejects 403 if role!='admin'\n\nSurvey listing\n  admins: own drafts merged with\n          all active surveys\n  others: only active surveys",
      "lineHeight": 1.25
    },
