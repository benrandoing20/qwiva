      "boundElements": null,
      "updated": 1745800000000,
      "link": null,
      "locked": false,
      "text": "QwivaRAG class + module singleton\n_SemanticCache: LRU 512 \u00b7 24h TTL\n  \u00b7 0.92 cosine threshold\n  \u00b7 skipped when history present\n@cached_property: lazy clients\n  _openai \u00b7 _http (http2) \u00b7 _qdrant\n  _extra_kwargs \u00b7 _classify_kwargs\nPure helpers (module-level)\n  _rrf_merge \u00b7 _build_citations\n  _derive_evidence_grade\n  _expand_clinical_abbreviations\n  _strip_question_words\n  _suggestion_grounded\n  _row_to_chunk \u00b7 _qdrant_hit_to_chunk",
      "fontSize": 9,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "QwivaRAG class + module singleton\n_SemanticCache: LRU 512 \u00b7 24h TTL\n  \u00b7 0.92 cosine threshold\n  \u00b7 skipped when history present\n@cached_property: lazy clients\n  _openai \u00b7 _http (http2) \u00b7 _qdrant\n  _extra_kwargs \u00b7 _classify_kwargs\nPure helpers (module-level)\n  _rrf_merge \u00b7 _build_citations\n  _derive_evidence_grade\n  _expand_clinical_abbreviations\n  _strip_question_words\n  _suggestion_grounded\n  _row_to_chunk \u00b7 _qdrant_hit_to_chunk",
      "lineHeight": 1.25
    },
