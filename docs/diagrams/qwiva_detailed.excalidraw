    {
      "id": "b4_fol_t",
      "type": "text",
      "x": 1630,
      "y": 1922,
      "width": 1102,
      "height": 772,
      "angle": 0,
      "strokeColor": "#1e3a8a",
      "backgroundColor": "transparent",
