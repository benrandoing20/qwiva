    {
      "id": "qdrant_b",
      "type": "text",
      "x": 1320,
      "y": 1128,
      "width": 1120,
      "height": 120,
      "angle": 0,
      "strokeColor": "#9d174d",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
